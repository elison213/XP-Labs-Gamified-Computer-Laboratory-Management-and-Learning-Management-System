<Window x:Class="XPLabs.LockScreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#0B1220"
        Title="XPLabs LockScreen">
  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#111827" Offset="0"/>
        <GradientStop Color="#0B1220" Offset="1"/>
      </LinearGradientBrush>
    </Grid.Background>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Width="430"
            Padding="22"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#151B26"
            BorderBrush="#2D3748"
            BorderThickness="1"
            CornerRadius="14">
      <StackPanel>
        <TextBlock Text="XPLabs"
                   Foreground="#60A5FA"
                   FontSize="36"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Admin Login"
                   Foreground="#E2E8F0"
                   FontSize="24"
                   Margin="0,8,0,0"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Login in the kiosk for student access."
                   Foreground="#94A3B8"
                   FontSize="14"
                   Margin="0,8,0,0"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="This desktop unlock form is for authorized admins only."
                   Foreground="#94A3B8"
                   FontSize="13"
                   Margin="0,6,0,0"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>

        <Border Background="#0F172A"
                CornerRadius="10"
                Padding="12"
                Margin="0,16,0,0"
                BorderBrush="#334155"
                BorderThickness="1">
          <StackPanel>
            <TextBlock Text="STATUS" Foreground="#93C5FD" FontSize="11" />
            <TextBlock x:Name="StatusText" Text="Waiting for unlock..." Foreground="#E2E8F0" FontSize="13" Margin="0,6,0,0"/>
            <TextBlock x:Name="InfoText" Text="" Foreground="#94A3B8" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <Button x:Name="OverrideButton"
                Content="Admin Override Login"
                Height="38"
                Margin="0,14,0,0"
                HorizontalAlignment="Stretch"
                Click="OverrideButton_Click"/>

        <Border x:Name="OverridePanel"
                Background="#0F172A"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,10,0,0"
                Visibility="Collapsed">
          <StackPanel>
            <TextBlock Text="Admin ID or Email" Foreground="#CBD5E1" Margin="0,0,0,4"/>
            <TextBox x:Name="OverrideIdentifierInput" Height="32" Margin="0,0,0,8"/>
            <TextBlock Text="Password" Foreground="#CBD5E1" Margin="0,0,0,4"/>
            <PasswordBox x:Name="OverridePasswordInput" Height="32" Margin="0,0,0,10"/>
            <Button Content="Unlock This PC" Height="34" Click="SubmitOverrideButton_Click"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <TextBlock Grid.Row="1"
               Text="Ctrl+Alt+Del cannot be fully disabled on Windows."
               Foreground="#475569"
               FontSize="12"
               Margin="0,0,0,14"
               HorizontalAlignment="Center"/>
  </Grid>
</Window>

