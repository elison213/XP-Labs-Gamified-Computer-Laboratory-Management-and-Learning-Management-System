<Window x:Class="XPLabs.LockScreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#0F172A"
        Title="XPLabs LockScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32">
      <TextBlock Text="XPLabs"
                 Foreground="#A5B4FC"
                 FontSize="48"
                 FontWeight="Bold"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="This PC is locked"
                 Foreground="#E2E8F0"
                 FontSize="28"
                 Margin="0,12,0,0"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Scan your QR at the door kiosk or wait for teacher unlock."
                 Foreground="#94A3B8"
                 FontSize="16"
                 Margin="0,10,0,0"
                 TextAlignment="Center"
                 HorizontalAlignment="Center"/>

      <Border Background="#1E293B" CornerRadius="12" Padding="16" Margin="0,22,0,0" BorderBrush="#334155" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="Status" Foreground="#94A3B8" FontSize="12" TextTransform="Uppercase" />
          <TextBlock x:Name="StatusText" Text="Waiting for unlock..." Foreground="#E2E8F0" FontSize="14" Margin="0,6,0,0"/>
          <TextBlock x:Name="InfoText" Text="" Foreground="#64748B" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <StackPanel Margin="0,16,0,0">
        <Button x:Name="OverrideButton"
                Content="Authorized User Login"
                Width="260"
                Height="40"
                HorizontalAlignment="Center"
                Click="OverrideButton_Click"/>

        <Border x:Name="OverridePanel"
                Background="#1E293B"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,12,0,0"
                Visibility="Collapsed">
          <StackPanel>
            <TextBox x:Name="OverrideIdentifierInput" Height="32" Margin="0,0,0,8"/>
            <PasswordBox x:Name="OverridePasswordInput" Height="32" Margin="0,0,0,8"/>
            <Button Content="Unlock This PC" Height="34" Click="SubmitOverrideButton_Click"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </StackPanel>

    <TextBlock Grid.Row="1"
               Text="Ctrl+Alt+Del cannot be fully disabled on Windows."
               Foreground="#475569"
               FontSize="12"
               Margin="0,0,0,14"
               HorizontalAlignment="Center"/>
  </Grid>
</Window>

